PORT=3002
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=
DATABASE_URL=
TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
INTERNAL_SERVICE_KEY=
# Base URL of the Lambda API — used by retrieve_documents to call /internal/retrieve
# No trailing slash. e.g. https://qh9a33hgbd.execute-api.ap-south-1.amazonaws.com
API_BASE_URL=
# URL of the relay service — used by the approval gate to route write-tool confirmations to the user
RELAY_INTERNAL_URL=http://localhost:3001

# Web search provider: 'google' (default, uses GCP credits),
# 'tavily', or 'brave'
SEARCH_PROVIDER=google

# Required only if SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Required only if SEARCH_PROVIDER=brave
BRAVE_API_KEY=
