{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",

    "rootDir": ".",
    "outDir": "dist",

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["layers/common/nodejs/src/*"]
    },

    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/**/*.ts", "local/**/*.ts"],
  "exclude": ["node_modules", "dist", ".aws-sam", "layers", "**/*.test.ts"]
}
