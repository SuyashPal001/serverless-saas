{
  "name": "serverless-saas",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-tenant SaaS foundation",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "pnpm -r run type-check",
    "format": "prettier --write \"**/*.{ts,json,yaml,md}\""
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
