{
  "name": "aws-sam-typescript-baseline",
  "version": "1.0.0",
  "description": "TypeScript AWS SAM baseline with modular Lambda functions",
  "keywords": [
    "aws",
    "sam",
    "serverless",
    "lambda",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "npx nodemon --watch local --watch src --exec tsx local/server.ts",
    "start": "node dist/local/server.js",
    "sam-local": "sam local start-api --env-vars env.json",
    "build:ts": "tsc && tsc-alias",
    "build:local": "npm run build:ts && shx cp studioServiceAccountKey.json dist/",
    "build:sam": "npm run build:ts",
    "build": "npm run clean && npm run build:local",
    "sam:build": "npm run clean && npm run build:sam && sam build",
    "clean": "rimraf dist .aws-sam",
    "validate": "sam validate",
    "invoke:ping": "sam local invoke PingFunction --env-vars env.json -e events/ping-event.json",
    "deploy:dev": "sam deploy --config-file samconfig.dev.toml",
    "deploy:staging": "sam deploy --config-file samconfig.staging.toml",
    "deploy:prod": "sam deploy --config-file samconfig.prod.toml",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@aws-sdk/client-eventbridge": "^3.940.0",
    "@aws-sdk/client-secrets-manager": "^3.940.0",
    "@aws-sdk/client-sns": "^3.940.0",
    "@aws-sdk/client-ssm": "^3.940.0",
    "@types/aws-lambda": "^8.10.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.11",
    "rimraf": "^6.1.2",
    "shx": "^0.4.0",
    "ts-node": "^1.7.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.932.0",
    "@aws-sdk/client-kms": "^3.965.0",
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/client-ses": "^3.932.0",
    "@aws-sdk/client-sts": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.965.0",
    "@fit-earn-meditate/backend-shared-models": "^5.11.268",
    "@types/moment": "^2.11.29",
    "@types/moment-timezone": "^0.5.13",
    "@vendia/serverless-express": "^4.12.6",
    "axios": "^1.13.2",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "ejs": "^4.0.1",
    "express": "^4.21.0",
    "firebase-admin": "^13.6.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "moment": "^2.30.1",
    "moment-timezone": "^0.6.0",
    "mongoose": "^6.5.3",
    "multer": "^2.0.2",
    "razorpay": "^2.9.6",
    "shootmail": "^2.1.9",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  }
}
