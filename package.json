{
  "name": "serverless-saas",
  "version": "0.0.1",
  "private": true,
  "description": "Multi-tenant SaaS foundation",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "clean": "find . -name 'dist' -type d -not -path '*/node_modules/*' -exec rm -rf {} + && find . -name 'tsconfig.tsbuildinfo' -delete",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "pnpm -r run type-check",
    "format": "prettier --write \"**/*.{ts,json,yaml,md}\"",
    "rebuild": "pnpm run clean && pnpm run build"
  }
}
